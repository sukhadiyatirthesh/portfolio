        </div>
        {% else %}
        <div style="font-size: 4rem; font-weight:800; color:var(--primary); line-height:1;">4.55X</div>
        <div style="font-size: 1.2rem; font-weight:600; margin-top:8px;">Highest Achieved ROAS</div>
        <div style="font-size: 0.9rem; color:var(--text-muted); margin-top:16px; border-top: 1px solid var(--border); padding-top:16px;">
