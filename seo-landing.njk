---
pagination:
  data: pSEO
  size: 1
  alias: pageData
permalink: "services/{{ pageData.slug }}/index.html"
layout: landing-layout.html
---

<style>
  /* Premium Landing Content Styles */
  .premium-section {
    padding: 80px 0;
    position: relative;
    border-top: 1px solid var(--border);
  }
  .premium-section-alt {
    background: var(--bg-alt);
  }
  .section-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 50px;
  }
  .section-header h2 {
    font-size: 2.5rem;
    font-family: var(--font-heading);
    margin-bottom: 16px;
    letter-spacing: -0.5px;
  }
  .section-header p {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.6;
  }
  
  /* Why Choose Us Grid */
  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 24px;
  }
  .benefit-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 32px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .benefit-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    border-color: rgba(255,255,255,0.1);
  }
  .benefit-icon {
    width: 48px;
    height: 48px;
    background: rgba(37, 99, 235, 0.1);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    margin-bottom: 20px;
  }
  .benefit-card h3 {
    font-size: 1.25rem;
    margin-bottom: 12px;
  }
  .benefit-card p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.6;
  }

  /* Dynamic Deep Dive Split */
  .deep-dive {
    display: flex;
    align-items: center;
    gap: 60px;
  }
  .deep-dive-text {
    flex: 1;
  }
  .deep-dive-text h2 {
    font-size: 2.2rem;
    margin-bottom: 24px;
    font-family: var(--font-heading);
  }
  .deep-dive-text p {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 24px;
  }
  .deep-dive-visual {
    flex: 1;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }
  .deep-dive-visual::before {
    content: '';
    position: absolute;
    width: 150%;
    height: 150%;
    background: radial-gradient(circle at center, rgba(37, 99, 235, 0.1) 0%, transparent 60%);
  }

  /* Process Timeline */
  .process-timeline {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 30px;
    position: relative;
  }
  .process-step {
    text-align: left;
    position: relative;
    padding-top: 30px;
    border-top: 2px dashed var(--border);
  }
  .process-step::before {
    content: '';
    position: absolute;
    top: -9px;
    left: 0;
    width: 16px;
    height: 16px;
    background: var(--primary);
    border-radius: 50%;
    box-shadow: 0 0 0 4px var(--bg);
  }
  .process-step-num {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--primary);
    letter-spacing: 1px;
    margin-bottom: 8px;
    display: block;
  }
  .process-step h3 {
    font-size: 1.2rem;
    margin-bottom: 12px;
  }
  .process-step p {
    color: var(--text-muted);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  /* FAQs */
  .faq-container {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .faq-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }
  .faq-summary {
    padding: 20px 24px;
    font-size: 1.1rem;
    font-weight: 500;
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .faq-summary::-webkit-details-marker {
    display: none;
  }
  .faq-summary::after {
    content: '+';
    font-size: 1.5rem;
    color: var(--primary);
    transition: transform 0.3s;
  }
  .faq-item[open] .faq-summary::after {
    transform: rotate(45deg);
  }
  .faq-content {
    padding: 0 24px 24px;
    color: var(--text-muted);
    line-height: 1.6;
    border-top: 1px solid rgba(255,255,255,0.05);
    margin-top: 10px;
    padding-top: 20px;
  }
  
  @media (max-width: 768px) {
    .deep-dive { flex-direction: column; }
    .process-timeline { grid-template-columns: 1fr; border-top: none; gap: 40px; }
    .process-step { border-top: none; border-left: 2px dashed var(--border); padding-top: 0; padding-left: 30px; }
    .process-step::before { top: 0; left: -9px; }
  }
</style>

<!-- DYNAMIC DEEP DIVE SECTION -->
<section class="premium-section">
